<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Edit chat</title>
    <link rel="stylesheet" href="style.css" />
  </head>
  <body>
    <p>Edit your chat :<%=chat._id %></p>

    <form method="POST" action="/chats/<%= chat._id%>?_method=PUT">
      <textarea name="msg" rows="5" cols="10"><%=chat.msg%></textarea>
      <button>Edit Chat</button>
    </form>
  </body>
</html>
