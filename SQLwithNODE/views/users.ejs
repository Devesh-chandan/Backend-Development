<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Users Page</title>
    <link rel="stylesheet" href="style.css" />
  </head>
  <body>
    <!-- Your visible content goes here -->
    <h1>This page show details of all users</h1>
    <style>
      table,
      th,
      td {
        border: 1px solid black;
      }
    </style>

    <table>
      <tr>
        <th>id</th>
        <th>username</th>
        <th>email</th>
        <th>password</th>
      </tr>

      <% for (let user of data) { %>
      <tr>
        <td><%= user.id %></td>
        <td><%= user.username %></td>
        <td><%= user.email %></td>
        <td><%= user.password %></td>
        <td>
          <form method="GET" action="/users/<%=user.id%>/edit">
            <button>Edit</button>
          </form>
        </td>
      </tr>
      <% } %>
    </table>

    <script src="index.js"></script>
  </body>
</html>
