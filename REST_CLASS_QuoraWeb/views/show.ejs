<!DOCTYPE html>
<html lang="en">
  <head>
    <title>View POST</title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <h1>Show Post</h1>

    <% if (post) { %>
    <p>id: <%= post.id %></p>
    <div class="post">
      <h3 class="user">@<%= post.username %></h3>
      <h3 class="content"><%= post.content %></h3>
    </div>
    <% } else { %>
    <h2>Post not found ❌</h2>
    <% } %>
  </body>
</html>
