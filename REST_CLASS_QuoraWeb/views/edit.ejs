<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Edit POST</title>
  </head>
  <body>
    <h1>Edit postPost</h1>
    <p>post id:<%=post.id %></p>
    <p>post content:<%=post.username %></p>
    <form method="post" action="/posts/<%=post.id%>?_method=PATCH">
      <textarea rows="10" cols="20" name="content"><%=post.content %></textarea>
      <button>Edit</button>
    </form>
  </body>
</html>
